## doc-rag server environment (example)
#
# Copy to .env and edit:
#   cp .env.example .env
#
# Then run:
#   docker compose up -d --build
#

# Bind address / port (0.0.0.0 to listen on LAN)
DOC_RAG_HTTP_HOST=0.0.0.0
DOC_RAG_HTTP_PORT=3333

# Optional: protect MCP + UI with an API key.
# If set, clients must send:
#   Authorization: Bearer <key>
# UI can be opened as:
#   http://<host>:3333/ui?key=<key>
#DOC_RAG_API_KEY=change-me

# Origin allow-list (only used if client sends Origin header).
# Comma-separated.
DOC_RAG_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost,http://192.168.1.1

# Optional: request log file inside container/host filesystem
DOC_RAG_HTTP_LOG=/app/build/http.log

# SSE keepalive interval (seconds)
DOC_RAG_SSE_KEEPALIVE_SEC=25

# Tool execution limits
DOC_RAG_MAX_CONCURRENCY=4
DOC_RAG_TOOL_TIMEOUT_SEC=30

# Rate limit (token bucket per client IP). 0 = disabled.
DOC_RAG_RATE_LIMIT_RPS=0
DOC_RAG_RATE_LIMIT_BURST=5

# UI upload limit (MB)
DOC_RAG_UI_MAX_UPLOAD_MB=100

# Optional: when returning doc_search results, expose full source paths
# (otherwise only basenames are shown).
DOC_RAG_EXPOSE_SOURCE_PATHS=0

